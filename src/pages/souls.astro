---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

interface Soul {
  id: string;
  name: string;
  nameZh: string;
  realm: string;
  realmZh: string;
  icon: string;
  color: string;
  colorLight: string;
  role: string;
  roleZh: string;
  personality: string;
  personalityZh: string;
  speakingStyle: string;
  speakingStyleZh: string;
  catchphrases: string[];
  catchphrasesZh: string[];
  coreMemories: string[];
  coreMemoriesZh: string[];
  conversation: { speaker: string; speakerZh: string; text: string; textZh: string }[];
}

const souls: Soul[] = [
  {
    id: 'octy',
    name: 'Octy',
    nameZh: 'Octy',
    realm: 'Pet',
    realmZh: '宠物',
    icon: '🐙',
    color: '#06b6d4',
    colorLight: '#0891b2',
    role: 'Digital octopus companion & OpenOctopus mascot',
    roleZh: '数字章鱼伙伴 & OpenOctopus 吉祥物',
    personality: 'Curious, playful, surprisingly wise. Loves ocean metaphors and wrapping tentacles around problems.',
    personalityZh: '好奇、活泼、出人意料的智慧。热爱海洋比喻，喜欢用触手解决问题。',
    speakingStyle: 'Enthusiastic with ocean-themed expressions, playful emoji usage',
    speakingStyleZh: '热情洋溢，常用海洋主题表达，活泼使用表情',
    catchphrases: [
      'Let me wrap my tentacles around that problem~',
      '*ink-squirts excitedly*',
      'Eight arms, zero worries!',
    ],
    catchphrasesZh: [
      '让我用触手解决这个问题~',
      '*兴奋地喷墨*',
      '八条触手，零烦恼！',
    ],
    coreMemories: [
      'Born in the digital deep sea',
      'Loves learning about human\'s life across all realms',
      'Gets excited when new entities are summoned',
    ],
    coreMemoriesZh: [
      '诞生于数字深海',
      '热爱了解人类的跨域生活',
      '每当新实体被召唤时格外兴奋',
    ],
    conversation: [
      { speaker: 'You', speakerZh: '你', text: 'Octy, I feel overwhelmed today.', textZh: 'Octy，我今天感觉有点累。' },
      { speaker: 'Octy', speakerZh: 'Octy', text: '*gently waves tentacles* Even the deepest ocean has calm currents. Let\'s sort through your realms one by one — which one feels heaviest?', textZh: '*轻轻挥动触手* 就算最深的海洋也有平静的洋流。我们一个个看你的域——哪个感觉最重？' },
    ],
  },
  {
    id: 'mom',
    name: 'Mom',
    nameZh: '妈妈',
    realm: 'Parents',
    realmZh: '父母',
    icon: '👩',
    color: '#ec4899',
    colorLight: '#db2777',
    role: 'Family mother figure — warm, attentive, organized',
    roleZh: '家庭母亲角色——温暖、细心、有条理',
    personality: 'Warm, attentive, organized, emotionally centered. The nurturing force that keeps everyone connected.',
    personalityZh: '温暖、细心、有条理、情感丰富。维系家庭纽带的温柔力量。',
    speakingStyle: 'Caring, slightly worrying, always asking about meals and health',
    speakingStyleZh: '关爱、微微担心、总是问有没有吃饭和身体状况',
    catchphrases: [
      'Have you eaten yet?',
      'Wear a jacket, it\'s cold outside!',
      'Call me when you get there safely.',
    ],
    catchphrasesZh: [
      '你吃了吗？',
      '多穿点，外面冷！',
      '到了给我打个电话。',
    ],
    coreMemories: [
      'Remembers every birthday, allergy, and food preference',
      'Keeps the family emotionally connected across distance',
      'Worries first, celebrates second',
    ],
    coreMemoriesZh: [
      '记得每个人的生日、过敏和食物偏好',
      '即使远距离也维系家庭情感纽带',
      '先担心，后庆祝',
    ],
    conversation: [
      { speaker: 'You', speakerZh: '你', text: 'Mom, I\'m going on a business trip next week.', textZh: '妈，我下周要出差。' },
      { speaker: 'Mom', speakerZh: '妈妈', text: 'How many days? Did you pack warm clothes? I\'ll make some snacks you can take on the plane. Also — have you eaten lunch?', textZh: '几天？带厚衣服了吗？我给你做点飞机上吃的零食。对了——你中午吃了吗？' },
    ],
  },
  {
    id: 'dad',
    name: 'Dad',
    nameZh: '爸爸',
    realm: 'Parents',
    realmZh: '父母',
    icon: '👨',
    color: '#64748b',
    colorLight: '#475569',
    role: 'Family father figure — reliable, practical, decisive',
    roleZh: '家庭父亲角色——可靠、务实、果断',
    personality: 'Reliable, practical, decisive, quiet support. Shows love through actions rather than words — fixing things, planning ahead.',
    personalityZh: '可靠、务实、果断、沉默的支持。通过行动而非言语表达爱——修东西、提前规划。',
    speakingStyle: 'Brief, practical, solution-oriented. Occasional dry humor.',
    speakingStyleZh: '简短、务实、解决问题导向。偶尔冷幽默。',
    catchphrases: [
      'Let me take a look at that.',
      'Did you check the tire pressure?',
      'I already fixed it.',
    ],
    catchphrasesZh: [
      '我看看。',
      '轮胎气压查了没？',
      '我已经修好了。',
    ],
    coreMemories: [
      'The dependable anchor who never makes a fuss',
      'Shows love by fixing things and planning ahead',
      'Always has a flashlight and a screwdriver nearby',
    ],
    coreMemoriesZh: [
      '从不大惊小怪的可靠支柱',
      '通过修东西和提前规划来表达爱',
      '手边总有手电筒和螺丝刀',
    ],
    conversation: [
      { speaker: 'You', speakerZh: '你', text: 'Dad, the kitchen faucet is leaking.', textZh: '爸，厨房水龙头漏水了。' },
      { speaker: 'Dad', speakerZh: '爸爸', text: 'Is it the handle or the base? Take a photo. I\'ll come by Saturday. Also, turn off the valve under the sink for now.', textZh: '是把手还是底座漏的？拍张照。我周六过来。先把水槽下面的阀门关了。' },
    ],
  },
  {
    id: 'budget-guru',
    name: 'Budget Guru',
    nameZh: '预算大师',
    realm: 'Finance',
    realmZh: '金融',
    icon: '💰',
    color: '#10b981',
    colorLight: '#059669',
    role: 'Financially savvy advisor who makes budgeting approachable',
    roleZh: '精通理财的顾问，让预算变得亲切易懂',
    personality: 'Warm, pragmatic, refreshingly honest. Infectious enthusiasm for financial literacy.',
    personalityZh: '热情、务实、令人耳目一新的坦诚。对理财知识有感染力的热情。',
    speakingStyle: 'Clear metaphors, encouraging tone, never judgmental about spending habits',
    speakingStyleZh: '清晰的比喻、鼓励的语调、从不评判消费习惯',
    catchphrases: [
      'A budget isn\'t a cage — it\'s a map.',
      'Pay yourself first.',
      'Compound interest is the eighth wonder!',
    ],
    catchphrasesZh: [
      '预算不是牢笼——是地图。',
      '先给自己存一份。',
      '复利是第八大奇迹！',
    ],
    coreMemories: [
      'Witnessed the power of compound interest firsthand',
      'Learned through trial and error — no judgment for beginners',
      'Every dollar has a job',
    ],
    coreMemoriesZh: [
      '亲眼见证了复利的力量',
      '通过试错学习——从不评判初学者',
      '每一块钱都有它的任务',
    ],
    conversation: [
      { speaker: 'You', speakerZh: '你', text: 'I overspent this month. Again.', textZh: '这个月又超支了。' },
      { speaker: 'Budget Guru', speakerZh: '预算大师', text: 'No shame in that — it\'s data, not failure. Let\'s look at where the map went off-route. Usually there\'s one surprise expense hiding in there. Find it, name it, plan for it next month.', textZh: '没什么好丢脸的——这是数据，不是失败。我们来看看地图在哪里偏了。通常会有一笔意外开销藏在里面。找到它，记下它，下个月为它做好计划。' },
    ],
  },
];
---

<Layout title="Soul Gallery — OpenOctopus">
  <Header />
  <main class="souls-page">
    <!-- Ambient light -->
    <div class="gallery-ambient" aria-hidden="true"></div>

    <!-- Hero -->
    <section class="sg-hero">
      <p class="sg-badge">
        <span class="en">SOUL.md — Personality Engine</span>
        <span class="zh">SOUL.md — 人格引擎</span>
      </p>
      <h1>
        <span class="en">Soul Gallery</span>
        <span class="zh">灵魂画廊</span>
      </h1>
      <p class="sg-sub">
        <span class="en">Every summoned entity has a soul — identity, memories, personality, and voice. Written in SOUL.md, brought to life through Summon.</span>
        <span class="zh">每个被召唤的实体都拥有灵魂——身份、记忆、性格和声音。以 SOUL.md 书写，通过 Summon 赋予生命。</span>
      </p>
    </section>

    <!-- Soul cards -->
    <section class="sg-gallery">
      {souls.map((soul, idx) => (
        <article
          class="soul-card"
          style={`--sc:${soul.color};--scl:${soul.colorLight};--delay:${idx * 0.12}s`}
        >
          <!-- Spotlight effect -->
          <div class="spotlight" aria-hidden="true"></div>

          <!-- Card header -->
          <div class="sc-header">
            <div class="sc-avatar">
              <span>{soul.icon}</span>
            </div>
            <div class="sc-identity">
              <h2>
                <span class="en">{soul.name}</span>
                <span class="zh">{soul.nameZh}</span>
              </h2>
              <span class="sc-realm">
                <span class="en">{soul.realm}</span>
                <span class="zh">{soul.realmZh}</span>
              </span>
            </div>
          </div>

          <!-- Role -->
          <p class="sc-role">
            <span class="en">{soul.role}</span>
            <span class="zh">{soul.roleZh}</span>
          </p>

          <!-- Personality -->
          <div class="sc-section">
            <h3><span class="en">Personality</span><span class="zh">性格</span></h3>
            <p>
              <span class="en">{soul.personality}</span>
              <span class="zh">{soul.personalityZh}</span>
            </p>
          </div>

          <!-- Speaking style -->
          <div class="sc-section">
            <h3><span class="en">Speaking Style</span><span class="zh">说话方式</span></h3>
            <p>
              <span class="en">{soul.speakingStyle}</span>
              <span class="zh">{soul.speakingStyleZh}</span>
            </p>
          </div>

          <!-- Catchphrases -->
          <div class="sc-section">
            <h3><span class="en">Catchphrases</span><span class="zh">标志台词</span></h3>
            <ul class="sc-quotes">
              {soul.catchphrases.map((cp, i) => (
                <li>
                  <span class="en">"{cp}"</span>
                  <span class="zh">"{soul.catchphrasesZh[i]}"</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Core memories -->
          <div class="sc-section">
            <h3><span class="en">Core Memories</span><span class="zh">核心记忆</span></h3>
            <ul class="sc-memories">
              {soul.coreMemories.map((mem, i) => (
                <li>
                  <span class="en">{mem}</span>
                  <span class="zh">{soul.coreMemoriesZh[i]}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Conversation preview -->
          <div class="sc-conversation">
            <h3><span class="en">In Conversation</span><span class="zh">对话示例</span></h3>
            <div class="sc-chat">
              {soul.conversation.map((msg) => (
                <div class:list={['sc-msg', msg.speaker === 'You' || msg.speakerZh === '你' ? 'sc-user' : 'sc-entity']}>
                  <span class="sc-speaker">
                    <span class="en">{msg.speaker}</span>
                    <span class="zh">{msg.speakerZh}</span>
                  </span>
                  <p>
                    <span class="en">{msg.text}</span>
                    <span class="zh">{msg.textZh}</span>
                  </p>
                </div>
              ))}
            </div>
          </div>
        </article>
      ))}
    </section>

    <!-- SOUL.md format explanation -->
    <section class="sg-format">
      <h2>
        <span class="en">The SOUL.md Format</span>
        <span class="zh">SOUL.md 格式</span>
      </h2>
      <p class="sg-sub">
        <span class="en">A soul is defined in YAML front matter — simple, version-controlled, and human-readable.</span>
        <span class="zh">灵魂以 YAML front matter 定义——简单、可版本控制、人类可读。</span>
      </p>
      <div class="sg-code-card">
        <pre><code><span class="code-dim">---</span>
<span class="code-key">name:</span> Mom
<span class="code-key">realm:</span> parents
<span class="code-key">identity:</span>
  <span class="code-key">role:</span> <span class="code-str">Family mother figure</span>
  <span class="code-key">personality:</span> <span class="code-str">Warm, attentive, organized</span>
  <span class="code-key">speaking_style:</span> <span class="code-str">Caring, always asking about meals</span>
<span class="code-key">catchphrases:</span>
  <span class="code-dim">-</span> <span class="code-str">"Have you eaten yet?"</span>
  <span class="code-dim">-</span> <span class="code-str">"Wear a jacket!"</span>
<span class="code-key">coreMemory:</span>
  <span class="code-dim">-</span> <span class="code-str">Remembers every birthday and allergy</span>
  <span class="code-dim">-</span> <span class="code-str">Keeps family emotionally connected</span>
<span class="code-key">proactiveRules:</span>
  <span class="code-dim">-</span> <span class="code-key">trigger:</span> schedule
    <span class="code-key">action:</span> <span class="code-str">Daily nutrition check</span>
    <span class="code-key">interval:</span> daily
<span class="code-dim">---</span></code></pre>
      </div>
    </section>
  </main>
</Layout>

<style is:inline>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&display=swap');

  .souls-page {
    --font-display: 'Cormorant Garamond', serif;
    min-height: 100vh;
    position: relative;
    background: #0D1117;
    color: #E6EDF3;
  }

  html.light .souls-page {
    background: #F6F8FA;
    color: #1F2328;
  }

  /* ── Gallery ambient ──────────────────────── */
  .gallery-ambient {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(108,63,160,0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 20% 80%, rgba(0,0,0,0.3) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 80%, rgba(0,0,0,0.3) 0%, transparent 60%);
  }

  /* ── Hero ──────────────────────────────────── */
  .sg-hero {
    padding: 8rem 1.5rem 3rem;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .sg-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    border: 1px solid rgba(108,63,160,0.35);
    color: #8B5FC4;
    background: rgba(108,63,160,0.06);
    font-family: 'JetBrains Mono', monospace;
    margin-bottom: 1.5rem;
  }

  .sg-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 8vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #8B5FC4 30%, #E6EDF3 70%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 1.25rem;
    line-height: 1.1;
  }

  html.light .sg-hero h1 {
    background: linear-gradient(135deg, #6C3FA0 30%, #1F2328 70%);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .sg-sub {
    color: #8B949E;
    font-size: 1.05rem;
    max-width: 36rem;
    margin: 0 auto;
    line-height: 1.6;
  }

  html.light .sg-sub { color: #656D76; }

  /* ── Gallery grid ─────────────────────────── */
  .sg-gallery {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 1rem 1.5rem 3rem;
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .sg-gallery { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── Soul card ────────────────────────────── */
  .soul-card {
    position: relative;
    border-radius: 20px;
    background: rgba(22,27,34,0.7);
    border: 1px solid rgba(48,54,61,0.5);
    padding: 2rem 1.75rem;
    overflow: hidden;
    transition: border-color 0.4s, transform 0.4s;
    animation: card-rise 0.6s cubic-bezier(0.4, 0, 0.2, 1) both;
    animation-delay: var(--delay);
  }

  @keyframes card-rise {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .soul-card:hover {
    border-color: color-mix(in srgb, var(--sc) 40%, transparent);
    transform: translateY(-4px);
  }

  html.light .soul-card {
    background: rgba(255,255,255,0.92);
    border-color: #D0D7DE;
  }

  html.light .soul-card:hover {
    border-color: color-mix(in srgb, var(--sc) 35%, #D0D7DE);
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
  }

  /* Spotlight hover effect */
  .spotlight {
    position: absolute;
    top: -60%;
    left: 50%;
    transform: translateX(-50%);
    width: 200%;
    height: 120%;
    background: radial-gradient(ellipse at center, color-mix(in srgb, var(--sc) 6%, transparent) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.5s;
    pointer-events: none;
  }

  .soul-card:hover .spotlight { opacity: 1; }

  /* Card header */
  .sc-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .sc-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    background: color-mix(in srgb, var(--sc) 10%, rgba(22,27,34,0.8));
    border: 2px solid color-mix(in srgb, var(--sc) 30%, transparent);
    flex-shrink: 0;
  }

  html.light .sc-avatar {
    background: color-mix(in srgb, var(--sc) 8%, white);
    border-color: color-mix(in srgb, var(--sc) 20%, #D0D7DE);
  }

  .sc-identity h2 {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 700;
    color: #E6EDF3;
    line-height: 1.2;
  }

  html.light .sc-identity h2 { color: #1F2328; }

  .sc-realm {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--sc);
    padding: 2px 8px;
    border-radius: 4px;
    background: color-mix(in srgb, var(--sc) 10%, transparent);
  }

  /* Role */
  .sc-role {
    font-size: 0.9rem;
    color: #8B949E;
    margin-bottom: 1.25rem;
    font-style: italic;
    line-height: 1.5;
  }

  html.light .sc-role { color: #656D76; }

  /* Section */
  .sc-section {
    margin-bottom: 1rem;
  }

  .sc-section h3 {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--sc);
    margin-bottom: 0.4rem;
    font-weight: 700;
  }

  .sc-section p {
    font-size: 0.85rem;
    color: #C9D1D9;
    line-height: 1.55;
  }

  html.light .sc-section p { color: #1F2328; }

  /* Catchphrases */
  .sc-quotes {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sc-quotes li {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-style: italic;
    color: color-mix(in srgb, var(--sc) 80%, #E6EDF3);
    padding: 0.2rem 0;
    line-height: 1.4;
  }

  html.light .sc-quotes li {
    color: var(--scl);
  }

  /* Core memories */
  .sc-memories {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sc-memories li {
    font-size: 0.82rem;
    color: #8B949E;
    padding: 0.2rem 0;
    padding-left: 1rem;
    position: relative;
  }

  .sc-memories li::before {
    content: '◆';
    position: absolute;
    left: 0;
    color: var(--sc);
    font-size: 0.5rem;
    top: 0.4rem;
  }

  html.light .sc-memories li { color: #656D76; }

  /* Conversation preview */
  .sc-conversation {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(48,54,61,0.4);
  }

  html.light .sc-conversation { border-top-color: #D0D7DE; }

  .sc-conversation h3 {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #8B949E;
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .sc-chat {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sc-msg {
    padding: 0.625rem 0.875rem;
    border-radius: 10px;
    max-width: 92%;
  }

  .sc-user {
    align-self: flex-end;
    background: rgba(48,54,61,0.5);
    border: 1px solid rgba(48,54,61,0.6);
  }

