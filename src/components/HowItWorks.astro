---
const steps = [
  {
    number: '01',
    title: 'Create Realms',
    titleZh: '创建域',
    description: 'Divide your life into autonomous domains. Pet, finance, work, legal — each realm runs independently with its own knowledge base and agent team.',
    descriptionZh: '将人生划分为自治域。宠物、金融、工作、法律——每个域独立运行，拥有自己的知识库和 Agent 团队。',
    detail: 'tentacle realm create pet --template default',
  },
  {
    number: '02',
    title: 'Summon Entities',
    titleZh: '召唤实体',
    description: 'Add entities to each realm and summon them. Your pet gets memory, personality, and proactive behavior. Your car tracks maintenance. Your goals track progress.',
    descriptionZh: '向每个域添加实体并召唤它们。你的宠物获得记忆、性格和主动行为。你的车追踪保养。你的目标追踪进度。',
    detail: 'tentacle summon --realm pet --name "Momo" --type living',
  },
  {
    number: '03',
    title: 'Agents Collaborate',
    titleZh: 'Agent 协作',
    description: 'Agents act autonomously within their realm. When cross-realm coordination is needed, the central brain steps in — like a real octopus.',
    descriptionZh: 'Agent 在各自域内自主行动。当需要跨域协调时，中央大脑介入——就像真正的章鱼。',
    detail: '"I\'m going on vacation" → 4 realms respond simultaneously',
    detailZh: '「我要去度假」→ 4 个域同时响应',
  },
];
---

<section class="section-padding">
  <div class="section-container">
    <div class="text-center mb-16">
      <h2 class="section-title"><span class="en">How it works</span><span class="zh">工作原理</span></h2>
      <p class="section-subtitle mx-auto"><span class="en">Three steps. Eight arms. Every realm covered.</span><span class="zh">三步走。八条臂。覆盖每个域。</span></p>
    </div>

    <div class="max-w-3xl mx-auto space-y-8">
      {steps.map((s, i) => (
        <div class="card flex items-start gap-6 group">
          <div class="flex-shrink-0 w-14 h-14 rounded-xl bg-summon-gradient flex items-center justify-center text-white font-bold text-lg">
            {s.number}
          </div>
          <div class="flex-1">
            <h3 class="text-xl font-bold text-text-primary light:text-text-light-primary mb-2"><span class="en">{s.title}</span><span class="zh">{s.titleZh}</span></h3>
            <p class="text-text-secondary light:text-text-light-secondary text-sm leading-relaxed mb-3"><span class="en">{s.description}</span><span class="zh">{s.descriptionZh}</span></p>
            <code class="text-xs text-cyan/80 font-mono bg-abyss/50 light:bg-surface/50 px-3 py-1.5 rounded-md border border-border-dark/30 light:border-border-light/30 inline-block">
              <span class="en">{s.detail}</span><span class="zh">{s.detailZh || s.detail}</span>
            </code>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
