---
import { Image } from 'astro:assets';
import mascot from '../assets/brand/mascot.png';
---

<section class="section-padding">
  <div class="section-container">
    <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center gap-12">
      <!-- Mascot image -->
      <div class="flex-shrink-0">
        <div class="relative">
          <div class="absolute inset-0 glow-purple rounded-full scale-110"></div>
          <Image
            src={mascot}
            alt="Octo — the OpenOctopus mascot"
            class="relative w-64 h-64 object-contain animate-float"
            width={256}
          />
        </div>
      </div>

      <!-- Text -->
      <div>
        <h2 class="section-title"><span class="en">Meet Octo</span><span class="zh">认识 Octo</span></h2>
        <p class="text-text-secondary light:text-text-light-secondary leading-relaxed mb-6">
          <span class="en">A deep-sea octopus. Calm, multi-threaded, quietly brilliant. Eight arms juggling your entire life while one brain keeps it all in sync. The tentacle tips glow cyan when summoning entities to life.</span><span class="zh">一只深海章鱼。沉稳、多线程、默默出众。八条臂同时管理你的整个人生，一个大脑保持一切同步。召唤实体时，触手尖端发出青色光芒。</span>
        </p>
        <blockquote class="border-l-2 border-purple pl-4 italic text-text-secondary/80 light:text-text-light-secondary/80">
          <span class="en">"A deep-sea octopus, definitely."</span><span class="zh">"深海章鱼，没错。"</span>
        </blockquote>

        <!-- Personality pillars -->
        <div class="grid grid-cols-2 gap-3 mt-6">
          <div class="text-sm">
            <span class="text-cyan font-semibold"><span class="en">Multi-tasker</span><span class="zh">多任务处理</span></span>
            <p class="text-xs text-text-secondary/60 light:text-text-light-secondary/60"><span class="en">Watches all realms at once</span><span class="zh">同时关注所有域</span></p>
          </div>
          <div class="text-sm">
            <span class="text-cyan font-semibold"><span class="en">Summoner</span><span class="zh">召唤者</span></span>
            <p class="text-xs text-text-secondary/60 light:text-text-light-secondary/60"><span class="en">Glowing tips bring entities to life</span><span class="zh">发光触尖赋予实体生命</span></p>
          </div>
          <div class="text-sm">
            <span class="text-cyan font-semibold"><span class="en">Reliable</span><span class="zh">可靠</span></span>
            <p class="text-xs text-text-secondary/60 light:text-text-light-secondary/60"><span class="en">Steady, never rushed</span><span class="zh">沉稳，从不急躁</span></p>
          </div>
          <div class="text-sm">
            <span class="text-cyan font-semibold"><span class="en">Evolving</span><span class="zh">进化</span></span>
            <p class="text-xs text-text-secondary/60 light:text-text-light-secondary/60"><span class="en">Smartest invertebrate, always learning</span><span class="zh">最聪明的无脊椎动物，持续学习</span></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
