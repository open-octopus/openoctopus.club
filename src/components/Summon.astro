---
import { Image } from 'astro:assets';
import summonConcept from '../assets/brand/summon-concept.png';
import summonSequence from '../assets/brand/summon-sequence.png';

const entityTypes = [
  { type: 'Living', typeZh: '生命体', icon: '🐾', examples: 'Pet, family, friend', examplesZh: '宠物、家人、朋友', ability: 'Personality, dialogue, emotions', abilityZh: '性格、对话、情感' },
  { type: 'Asset', typeZh: '资产', icon: '🚗', examples: 'Car, house, portfolio', examplesZh: '汽车、房产、投资组合', ability: 'Status monitoring, cost reports', abilityZh: '状态监控、费用报告' },
  { type: 'Organization', typeZh: '组织', icon: '🏢', examples: 'Company, hospital', examplesZh: '公司、医院', ability: 'Process guides, contacts', abilityZh: '流程指南、联系人' },
  { type: 'Abstract', typeZh: '抽象', icon: '🎯', examples: 'Goal, project, habit', examplesZh: '目标、项目、习惯', ability: 'Progress tracking, alerts', abilityZh: '进度追踪、提醒' },
];

const conversation = [
  { name: 'You', nameZh: '你', icon: '👤', color: 'text-text-primary light:text-text-light-primary', msg: '"I\'m traveling for 5 days next week."', msgZh: '"我下周要出差 5 天。"' },
  { name: 'Momo (Pet)', nameZh: 'Momo（宠物）', icon: '🐾', color: 'text-amber-400', msg: '"Who\'s going to feed me and walk me for 5 days?!"', msgZh: '"谁来喂我遛我 5 天？！"' },
  { name: 'Mom (Parents)', nameZh: '妈妈（父母）', icon: '👩', color: 'text-pink-400', msg: '"Mom could come take care of Momo — she wanted to visit anyway."', msgZh: '"妈妈可以来照顾 Momo——她正好想来看看。"' },
  { name: 'Car (Vehicle)', nameZh: '车（车辆）', icon: '🚗', color: 'text-blue-400', msg: '"Charge to full before departure? Or taxi to the airport?"', msgZh: '"出发前充满电？还是打车去机场？"' },
  { name: 'Budget (Finance)', nameZh: '预算（金融）', icon: '💰', color: 'text-green-400', msg: '"Trip budget estimate: $800. Remember to save receipts."', msgZh: '"出行预算预估：¥5,600。记得保存发票。"' },
];
---

<section id="summon" class="section-padding">
  <div class="section-container">
    <div class="text-center mb-16">
      <h2 class="section-title">
        <span class="gradient-text">Summon</span> <span class="en">— The Killer Feature</span><span class="zh">— 核心功能</span>
      </h2>
      <p class="section-subtitle mx-auto">
        <span class="en">Turn data into a living agent. Your dog reminds you about vaccinations. Your mom suggests birthday gifts. Your car tracks maintenance costs.</span><span class="zh">将数据变为活的智能体。你的狗提醒你接种疫苗。你的妈妈推荐生日礼物。你的车追踪维护费用。</span>
      </p>
    </div>

    <!-- Summon concept image -->
    <div class="max-w-3xl mx-auto mb-16">
      <div class="relative">
        <div class="absolute inset-0 glow-cyan rounded-2xl"></div>
        <Image
          src={summonConcept}
          alt="Summon: tentacle transforms a grey silhouette into a living agent"
          class="rounded-2xl border border-border-dark/50 light:border-border-light/50 relative"
          width={768}
        />
      </div>
      <div class="text-center mt-6">
        <code class="text-sm text-text-secondary light:text-text-light-secondary font-mono bg-card-dark/50 light:bg-card-light px-4 py-2 rounded-lg border border-border-dark/50 light:border-border-light/50">
          <span class="en">Raw data → Structured Entity → <span class="text-cyan font-bold">SUMMON</span> → Agent with memory, personality &amp; initiative</span><span class="zh">原始数据 → 结构化实体 → <span class="text-cyan font-bold">SUMMON</span> → 拥有记忆、性格与主动性的 Agent</span>
        </code>
      </div>
    </div>

    <!-- Summon sequence -->
    <div class="max-w-4xl mx-auto mb-16">
      <Image
        src={summonSequence}
        alt="Summon transformation sequence: grey silhouette → tentacle touch → particles → living agent"
        class="rounded-2xl border border-border-dark/50 light:border-border-light/50"
        width={960}
      />
    </div>

    <!-- Entity types -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
      {entityTypes.map((e) => (
        <div class="card text-center">
          <div class="text-3xl mb-3">{e.icon}</div>
          <h3 class="font-bold text-sm mb-1 text-text-primary light:text-text-light-primary"><span class="en">{e.type}</span><span class="zh">{e.typeZh}</span></h3>
          <p class="text-xs text-text-secondary light:text-text-light-secondary mb-2"><span class="en">{e.examples}</span><span class="zh">{e.examplesZh}</span></p>
          <p class="text-xs text-cyan/70"><span class="en">{e.ability}</span><span class="zh">{e.abilityZh}</span></p>
        </div>
      ))}
    </div>

    <!-- Multi-agent conversation -->
    <div class="max-w-2xl mx-auto">
      <h3 class="text-lg font-bold text-center mb-6 text-text-primary light:text-text-light-primary">
        <span class="en">Summoned agents talk to each other</span><span class="zh">被召唤的 Agent 互相对话</span>
      </h3>
      <div class="space-y-3">
        {conversation.map((c, i) => (
          <div class:list={['flex items-start gap-3 p-4 rounded-xl transition-all', i === 0 ? 'bg-card-dark/80 light:bg-card-light border border-border-dark/50 light:border-border-light/50' : 'bg-card-dark/30 light:bg-card-light/50 border border-border-dark/30 light:border-border-light/30']}>
            <span class="text-2xl flex-shrink-0">{c.icon}</span>
            <div>
              <span class:list={['text-sm font-semibold', c.color]}><span class="en">{c.name}</span><span class="zh">{c.nameZh}</span></span>
              <p class="text-sm text-text-secondary light:text-text-light-secondary mt-1"><span class="en">{c.msg}</span><span class="zh">{c.msgZh}</span></p>
            </div>
          </div>
        ))}
        <!-- System summary -->
        <div class="flex items-start gap-3 p-4 rounded-xl border-2 border-cyan/30 bg-cyan/5">
          <span class="text-2xl flex-shrink-0">🐙</span>
          <div>
            <span class="text-sm font-semibold text-cyan">System</span>
            <p class="text-sm text-text-secondary light:text-text-light-secondary mt-1">
              <span class="en">"Here's your <strong class="text-text-primary light:text-text-light-primary">Trip Prep Checklist</strong>. Approve?"</span><span class="zh">"这是你的<strong class="text-text-primary light:text-text-light-primary">出行准备清单</strong>。确认？"</span>
            </p>
          </div>
        </div>
      </div>
      <p class="text-center text-sm text-text-secondary/60 light:text-text-light-secondary/60 mt-6">
        <span class="en">One sentence. Four realms. Zero manual coordination.</span><span class="zh">一句话，四个域，零手动协调。</span>
      </p>
    </div>
  </div>
</section>
