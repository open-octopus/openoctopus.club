---
import { Image } from 'astro:assets';
import banner from '../assets/brand/banner.png';
import heroBg from '../assets/brand/hero-bg.png';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Background image -->
  <div class="absolute inset-0">
    <Image
      src={heroBg}
      alt=""
      class="w-full h-full object-cover opacity-30 light:opacity-15"
      width={1920}
    />
  </div>
  <!-- Background effects -->
  <div class="absolute inset-0 bg-hero-glow light:opacity-50"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-purple/5 blur-3xl light:bg-purple/3"></div>

  <div class="section-container relative z-10 text-center">
    <!-- Battle cry -->
    <div class="mb-6">
      <span class="inline-block px-4 py-1.5 rounded-full text-sm font-semibold border border-cyan/30 text-cyan bg-cyan/5">
        <span class="en">Realm-native life agent system</span><span class="zh">Realm 原生人生 Agent 系统</span>
      </span>
    </div>

    <!-- Main headline -->
    <h1 class="text-6xl md:text-8xl font-black tracking-tighter mb-6">
      <span class="gradient-text">SUMMON!</span>
    </h1>

    <!-- Tagline -->
    <p class="text-xl md:text-2xl text-text-secondary light:text-text-light-secondary max-w-3xl mx-auto mb-4 leading-relaxed">
      <span class="en">Organize life by realms. Summon anything into a living agent.</span><span class="zh">将人生分域治理，将万物召唤为智能体。</span>
    </p>
    <p class="text-base text-text-secondary/70 light:text-text-light-secondary/70 max-w-2xl mx-auto mb-10">
      <span class="en">Not another unified chatbox. Each realm has its own knowledge base, agent team, and skill set.
      Like an octopus — each tentacle acts autonomously while the central brain coordinates everything.</span><span class="zh">不是又一个统一聊天框。每个域拥有自己的知识库、Agent 团队和技能集。如同章鱼——每条触手自主行动，中央大脑协调一切。</span>
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a href="#quickstart" class="btn-primary text-base">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" /></svg>
        <span class="en">Get Started</span><span class="zh">快速开始</span>
      </a>
      <a href="https://github.com/open-octopus/openoctopus" target="_blank" rel="noopener" class="btn-secondary text-base">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" /></svg>
        GitHub
      </a>
    </div>

    <!-- Banner image -->
    <div class="relative max-w-4xl mx-auto">
      <div class="absolute inset-0 glow-purple rounded-2xl"></div>
      <Image
        src={banner}
        alt="OpenOctopus — each tentacle connects to a life realm"
        class="rounded-2xl border border-border-dark/50 light:border-border-light/50 relative"
        width={960}
      />
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce text-text-secondary/50">
    <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 13l5 5 5-5M7 6l5 5 5-5" /></svg>
  </div>
</section>
