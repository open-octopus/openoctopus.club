---
const commands = [
  { comment: '# Install', commentZh: '# 安装', cmd: 'npm i -g openoctopus' },
  { comment: '# Initialize your life system', commentZh: '# 初始化你的人生系统', cmd: 'tentacle init' },
  { comment: '# Create your first realm', commentZh: '# 创建你的第一个域', cmd: 'tentacle realm create pet --template default' },
  { comment: '# Summon your first entity', commentZh: '# 召唤你的第一个实体', cmd: 'tentacle summon --realm pet --name "Momo" --type living' },
];
---

<section id="quickstart" class="section-padding">
  <div class="section-container">
    <div class="text-center mb-16">
      <h2 class="section-title"><span class="en">Quick Start</span><span class="zh">快速开始</span></h2>
      <p class="section-subtitle mx-auto"><span class="en">From zero to summoning in four commands.</span><span class="zh">四条命令，从零到召唤。</span></p>
    </div>

    <div class="max-w-2xl mx-auto">
      <div class="rounded-xl border border-border-dark/50 light:border-border-light/50 overflow-hidden">
        <!-- Terminal header -->
        <div class="flex items-center gap-2 px-4 py-3 bg-card-dark light:bg-gray-100 border-b border-border-dark/50 light:border-border-light/50">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/70"></div>
          </div>
          <span class="text-xs text-text-secondary light:text-text-light-secondary ml-2 font-mono">terminal</span>
        </div>

        <!-- Terminal body -->
        <div class="bg-abyss light:bg-gray-50 p-6 font-mono text-sm space-y-4">
          {commands.map((c) => (
            <div>
              <div class="text-text-secondary/50 light:text-text-light-secondary/50 text-xs mb-1"><span class="en">{c.comment}</span><span class="zh">{c.commentZh}</span></div>
              <div class="flex items-center gap-2">
                <span class="text-cyan select-none">$</span>
                <span class="text-text-primary light:text-text-light-primary">{c.cmd}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Alternative install methods -->
      <div class="flex flex-wrap justify-center gap-4 mt-8 text-sm text-text-secondary light:text-text-light-secondary">
        <span><span class="en">Also available via:</span><span class="zh">也可通过以下方式安装：</span></span>
        <code class="font-mono text-cyan/80">pnpm add -g openoctopus</code>
        <span class="text-border-dark light:text-border-light">|</span>
        <code class="font-mono text-cyan/80">docker compose up</code>
      </div>
    </div>
  </div>
</section>
