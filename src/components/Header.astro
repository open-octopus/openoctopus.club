---
import ThemeToggle from './ThemeToggle.astro';
import LanguageToggle from './LanguageToggle.astro';
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-border-dark/50 light:border-border-light/50 backdrop-blur-xl bg-abyss/80 light:bg-surface/80">
  <div class="section-container flex items-center justify-between h-16">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <img
        src="/favicon.png"
        alt="OpenOctopus"
        class="w-8 h-8"
      />
      <span class="text-lg font-bold">
        <span class="text-text-primary light:text-text-light-primary">Open</span><span class="text-purple">Octopus</span>
      </span>
    </a>

    <!-- Nav -->
    <nav class="hidden md:flex items-center gap-6 text-sm text-text-secondary light:text-text-light-secondary">
      <a href="#realms" class="hover:text-text-primary light:hover:text-text-light-primary transition-colors"><span class="en">Realms</span><span class="zh">域</span></a>
      <a href="#summon" class="hover:text-text-primary light:hover:text-text-light-primary transition-colors"><span class="en">Summon</span><span class="zh">召唤</span></a>
      <a href="#features" class="hover:text-text-primary light:hover:text-text-light-primary transition-colors"><span class="en">Features</span><span class="zh">功能</span></a>
      <a href="#quickstart" class="hover:text-text-primary light:hover:text-text-light-primary transition-colors"><span class="en">Get Started</span><span class="zh">快速开始</span></a>
      <span class="w-px h-4 bg-border-dark/50 light:bg-border-light/50"></span>
      <a href="/realms" class="hover:text-cyan transition-colors"><span class="en">Map</span><span class="zh">地图</span></a>
      <a href="/souls" class="hover:text-purple-light transition-colors"><span class="en">Souls</span><span class="zh">灵魂</span></a>
      <a href="/family" class="hover:text-amber-400 transition-colors"><span class="en">Family</span><span class="zh">家庭</span></a>
      <a href="https://github.com/open-octopus/openoctopus" target="_blank" rel="noopener" class="hover:text-text-primary light:hover:text-text-light-primary transition-colors">GitHub</a>
      <a href="https://discord.gg/mwNTk8g5fV" target="_blank" rel="noopener" class="hover:text-text-primary light:hover:text-text-light-primary transition-colors">Discord</a>
    </nav>

    <!-- Right side -->
    <div class="flex items-center gap-2">
      <LanguageToggle />
      <ThemeToggle />
      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden p-2 text-text-secondary hover:text-text-primary light:hover:text-text-light-primary" aria-label="Menu">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 5h14M3 10h14M3 15h14" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border-dark/50 light:border-border-light/50 bg-abyss/95 light:bg-surface/95">
    <nav class="section-container py-4 flex flex-col gap-3 text-sm text-text-secondary light:text-text-light-secondary">
      <a href="#realms" class="py-2 hover:text-text-primary"><span class="en">Realms</span><span class="zh">域</span></a>
      <a href="#summon" class="py-2 hover:text-text-primary"><span class="en">Summon</span><span class="zh">召唤</span></a>
      <a href="#features" class="py-2 hover:text-text-primary"><span class="en">Features</span><span class="zh">功能</span></a>
      <a href="#quickstart" class="py-2 hover:text-text-primary"><span class="en">Get Started</span><span class="zh">快速开始</span></a>
      <hr class="border-border-dark/30 light:border-border-light/30" />
      <a href="/realms" class="py-2 hover:text-cyan"><span class="en">Realm Map</span><span class="zh">域地图</span></a>
      <a href="/souls" class="py-2 hover:text-purple-light"><span class="en">Soul Gallery</span><span class="zh">灵魂画廊</span></a>
      <a href="/family" class="py-2 hover:text-amber-400"><span class="en">Family Hub</span><span class="zh">家庭中心</span></a>
      <a href="https://github.com/open-octopus/openoctopus" target="_blank" rel="noopener" class="py-2 hover:text-text-primary">GitHub</a>
      <a href="https://discord.gg/mwNTk8g5fV" target="_blank" rel="noopener" class="py-2 hover:text-text-primary">Discord</a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  // Close mobile menu on anchor click
  menu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>
