---
const packages = [
  {
    icon: '⚖️',
    name: 'Legal Advisor Team',
    description: 'Entity templates (lawyer, contract, statute) + 3 agents (contract reviewer, labor law advisor, case researcher) + legal search skill.',
    tags: ['entities', 'agents', 'skills'],
  },
  {
    icon: '🐾',
    name: 'Pet Care',
    description: 'Pet profile + health advisor agent + vet lookup skill + vaccination tracker + food recommendation.',
    tags: ['entities', 'agents', 'skills'],
  },
  {
    icon: '💰',
    name: 'Family Finance',
    description: 'Account entities + budget planner agent + investment analyzer + tax assistant + monthly reports.',
    tags: ['entities', 'agents', 'skills'],
  },
];
---

<section class="section-padding">
  <div class="section-container">
    <div class="text-center mb-16">
      <h2 class="section-title">
        <span class="gradient-text">RealmHub</span>
      </h2>
      <p class="section-subtitle mx-auto">
        Like an app store, but for life domains. Install a complete realm package in one click.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
      {packages.map((p) => (
        <div class="card group">
          <div class="text-4xl mb-4">{p.icon}</div>
          <h3 class="font-bold text-text-primary light:text-text-light-primary mb-2">{p.name}</h3>
          <p class="text-sm text-text-secondary light:text-text-light-secondary leading-relaxed mb-4">{p.description}</p>
          <div class="flex flex-wrap gap-2">
            {p.tags.map((t) => (
              <span class="text-xs px-2 py-0.5 rounded-md bg-purple/10 text-purple-light border border-purple/20">{t}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <p class="text-center text-sm text-text-secondary/60 light:text-text-light-secondary/60 mt-8">
      Each package includes: realm template, entity templates, agent configs, skill configs, and sample data.
    </p>
  </div>
</section>
